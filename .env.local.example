# Anthropic API キー（必須）
# https://console.anthropic.com でAPIキーを取得
ANTHROPIC_API_KEY=sk-ant-...

# 使用するモデル（省略時は claude-haiku-4-5 が使われます）
# 検証フェーズ: claude-haiku-4-5（低コスト）
# 品質重視:    claude-sonnet-4-6
# 最高品質:    claude-opus-4-8
ANTHROPIC_MODEL=claude-haiku-4-5

# note セッションクッキー（必須）
# 取得方法:
#   1. note.com にブラウザでログイン
#   2. DevTools (F12) → ネットワーク タブ
#   3. note.com/api/ で始まるリクエストをクリック
#   4. 「リクエストヘッダー」の cookie 欄を探す
#   5. cookie の中の「_note_session_v5=」の後ろの値だけをコピー
#      例: cookie に「_note_session_v5=abc123xyz...」とあれば「abc123xyz...」の部分
NOTE_SESSION_COOKIE=your_note_session_cookie_here
