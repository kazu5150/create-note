generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Article {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  inputText String
  title     String
  bodyJson  String
  score     Int
  noteUrl   String?
}
